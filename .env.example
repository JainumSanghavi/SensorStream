# Copy to .env (docker-compose reads it). These defaults match docker-compose.yml.
POSTGRES_USER=sensor
POSTGRES_PASSWORD=sensor
POSTGRES_DB=sensorstream
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Full async DSN used by the app (asyncpg driver).
# When running the app OUTSIDE docker (e.g. tests on the host), use localhost:
#   DATABASE_URL=postgresql+asyncpg://sensor:sensor@localhost:5432/sensorstream
DATABASE_URL=postgresql+asyncpg://sensor:sensor@db:5432/sensorstream

LOG_LEVEL=INFO
